# 이 파일을 복사해 .env 를 만든 뒤 값을 채우세요.
# cp .env.example .env

# Google AI Studio API 키 (Node 스크립트용 — 브라우저에 노출하지 마세요)
GEMINI_API_KEY=your_api_key_here

# 선택: gemini-2.0-flash-lite (기본), gemini-2.5-flash 등
# GEMINI_MODEL=gemini-2.0-flash-lite

# 파이프라인 (API 할당량 필요):
#   npm run gemini:test
#   npm run gemini:sync -- ethics
#   npm run gemini:sync -- tech-home
#   npm run gemini:sync -- all
