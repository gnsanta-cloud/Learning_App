{
  "name": "learning-app",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-pwa-icons.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "preview:pages": "npm run build && vite preview --base /Learning_App/",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "ebook:sync": "node scripts/crawl-ebook.mjs",
    "import:gemini": "node scripts/import-gemini-md.mjs",
    "import:gemini:ethics": "node scripts/import-gemini-ethics.mjs",
    "import:gemini:all": "node scripts/import-gemini-md.mjs && node scripts/import-gemini-ethics.mjs",
    "gemini:test": "node scripts/gemini-test.mjs",
    "gemini:ask": "node scripts/ask-gemini.mjs",
    "gemini:generate": "node scripts/gemini-generate-md.mjs",
    "gemini:sync": "node scripts/gemini-sync.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "cheerio": "^1.2.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0"
  }
}
